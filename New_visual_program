USE_MANUAL_SELECT = False
ALLOW_MANUAL_FALLBACK = True
EXPECTED_GAME_WIDTH = 800
EXPECTED_GAME_HEIGHT = 600
GAME_SIZE_TOLERANCE = 20

GRID_X_EDGES = [40, 120, 190, 280, 360, 440, 520, 600, 680, 770]
GRID_Y_EDGES = [90, 180, 280, 380, 470, 570]
